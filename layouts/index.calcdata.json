{{- $pokemon := dict -}}
{{- range where .Site.RegularPages "Section" "pokedex" -}}
  {{- $slug := path.Base .RelPermalink -}}
  {{- $forms := slice -}}
  {{- range .Params.forms -}}
    {{- if eq (.kind | default "skin") "form" -}}
      {{- $bs := .base_stats | default dict -}}
      {{- /* Build a flat learnset for the team builder: level-up + TMs +
              move tutors + egg moves. The frontmatter stores each entry
              as a dict with a `move` key — we extract just the names. */ -}}
      {{- $learnset := slice -}}
      {{- range .notable_moves -}}{{- with .move -}}{{- $learnset = $learnset | append . -}}{{- end -}}{{- end -}}
      {{- range .tms          -}}{{- with .move -}}{{- $learnset = $learnset | append . -}}{{- end -}}{{- end -}}
      {{- range .tutor_moves  -}}{{- with .move -}}{{- $learnset = $learnset | append . -}}{{- end -}}{{- end -}}
      {{- range .egg_moves    -}}{{- with .move -}}{{- $learnset = $learnset | append . -}}{{- end -}}{{- end -}}
      {{- $form := dict
            "name" (.name | default "Standard")
            "types" (.types | default (slice "Normal"))
            "abilities" (.abilities | default (slice))
            "hidden" (.hidden_ability | default "")
            "learnset" (uniq $learnset)
            "stats" (dict
              "hp"  (index $bs "hp"  | default 0)
              "atk" (index $bs "atk" | default 0)
              "def" (index $bs "def" | default 0)
              "spa" (index $bs "spa" | default 0)
              "spd" (index $bs "spd" | default 0)
              "spe" (index $bs "spe" | default 0))
      -}}
      {{- $forms = $forms | append $form -}}
    {{- end -}}
  {{- end -}}
  {{- /* Pre-evolution slugs from this species's evolution_family. The
          team builder walks this chain and merges ancestor learnsets so
          e.g. Cloyster's pickable moves include Shellder's level-up
          moves like Icicle Spear. */ -}}
  {{- /* evolution_family lives inside forms[0] in this site's frontmatter,
          not at the top level. */ -}}
  {{- $rawForms := .Params.forms | default (slice) -}}
  {{- $family := slice -}}
  {{- if gt (len $rawForms) 0 -}}
    {{- $family = (index $rawForms 0).evolution_family | default (slice) -}}
  {{- end -}}
  {{- $self := where $family "slug" $slug -}}
  {{- $preEvos := slice -}}
  {{- if $self -}}
    {{- $myDepth := (index $self 0).depth -}}
    {{- range $family -}}
      {{- if lt .depth $myDepth -}}{{- $preEvos = $preEvos | append .slug -}}{{- end -}}
    {{- end -}}
  {{- end -}}
  {{- if $forms -}}
    {{- $entry := dict "name" .Title "dex" (.Params.dex_number | default "0") "forms" $forms "preEvos" $preEvos -}}
    {{- $pokemon = merge $pokemon (dict $slug $entry) -}}
  {{- end -}}
{{- end -}}
{{- $moves := dict -}}
{{- range where .Site.RegularPages "Section" "moves" -}}
  {{- if eq (.Params.entry_kind | default "move") "move" -}}
    {{- $slug := path.Base .RelPermalink -}}
    {{- $power := .Params.power | default "—" -}}
    {{- $entry := dict
          "name" .Title
          "type" (.Params.move_type | default "Normal")
          "category" (.Params.category | default "Status")
          "power" $power
          "accuracy" (.Params.accuracy | default "—")
          "pp" (.Params.pp | default "—")
          "drain" (.Params.drain | default "")
    -}}
    {{- $moves = merge $moves (dict $slug $entry) -}}
  {{- end -}}
{{- end -}}
{{- dict "pokemon" $pokemon "moves" $moves | jsonify -}}
